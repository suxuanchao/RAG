```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Dependencies
venv/
.venv/
.env
.env.local
*.env.*

# Build/dist directories
build/
dist/
target/

# Logs
*.log

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
*.tmp

# System
.DS_Store
Thumbs.db

# Coverage
.coverage
coverage/
htmlcov/

# Python cache
.mypy_cache/
.pytest_cache/
```